{
  "displayName": "Homebridge Zigbee2MQTT",
  "name": "homebridge-z2m",
  "version": "1.11.0",
  "description": "Expose your Zigbee devices to HomeKit with ease, by integrating Zigbee2MQTT with Homebridge.",
  "license": "Apache-2.0",
  "homepage": "https://z2m.dev",
  "author": {
    "name": "Arno Moonen",
    "url": "https://arno.dev"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/itavero/homebridge-z2m.git"
  },
  "bugs": {
    "url": "https://github.com/itavero/homebridge-z2m/issues"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/itavero"
    },
    {
      "type": "buymeacoffee",
      "url": "https://www.buymeacoffee.com/arno"
    },
    {
      "type": "paypal",
      "url": "https://paypal.me/arnom/EUR"
    }
  ],
  "engines": {
    "node": "^20.18.0 || ^22.10.0 || ^24.0.0",
    "homebridge": "^1.8.0 || ^2.0.0-beta.0"
  },
  "main": "dist/index.js",
  "scripts": {
    "test": "vitest run --coverage && biome check src/ test/",
    "coverage": "vitest run --coverage && open coverage/lcov-report/index.html",
    "watch:test": "vitest",
    "lint": "biome check src/ test/",
    "lint-fix": "biome check --write src/ test/",
    "build": "rimraf ./dist && tsc",
    "start": "npm run build && npm link && homebridge -I -D",
    "smoke-test": "npm run build && ts-node scripts/smoke-test.ts",
    "smoke-test:setup": "ts-node scripts/setup-smoke-test.ts",
    "check-release": "release-it --dry-run -VV",
    "release": "release-it",
    "check-pre-release": "release-it --dry-run -VV --npm.tag=next",
    "pre-release": "release-it --npm.tag=next",
    "beta-release": "release-it --preRelease=beta --npm.tag=next",
    "check-beta-release": "release-it --dry-run -VV --preRelease=beta --npm.tag=next",
    "rc-release": "release-it --preRelease=rc --npm.tag=next",
    "check-rc-release": "release-it --dry-run -VV --preRelease=rc --npm.tag=next"
  },
  "keywords": [
    "homebridge-plugin",
    "zigbee2mqtt",
    "zigbee",
    "mqtt",
    "xiaomi",
    "aqara",
    "philips",
    "signify",
    "hue",
    "ikea",
    "tradfri",
    "homekit",
    "tuya",
    "lonsonho",
    "osram",
    "innr",
    "gledopto",
    "sonoff",
    "lidl"
  ],
  "dependencies": {
    "color-convert": "^2.0.1",
    "mqtt": "^5.3.4",
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@release-it/keep-a-changelog": "^7.0.1",
    "@types/color-convert": "^2.0.4",
    "@types/node": "^24.12.0",
    "@types/semver": "^7.7.1",
    "@vitest/coverage-v8": "^4.1.0",
    "aedes": "^0.51.3",
    "homebridge": "^2.0.0-beta.68",
    "nodemon": "^3.1.14",
    "release-it": "^19.2.4",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.0",
    "vitest-mock-extended": "^3.1.0",
    "vitest-sonar-reporter": "^3.0.0",
    "vitest-when": "^0.10.0"
  }
}
